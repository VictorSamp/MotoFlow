@using MotoFlow.Application.Members.CreateMember
@using MotoFlow.Web.Components.ViewModels.Members

@page "/members/new"
@inject MemberApiService MemberService
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card shadow-sm">

                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">Adicionar novo membro</h4>
                </div>

                <div class="card-body">

                    <p class="text-muted">
                        Preencha as informações para adicionar um novo membro.
                    </p>

                    <EditForm Model="model"
                              OnValidSubmit="Save"
                              FormName="create-member-model">

                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger mb-3" />

                        <div class="mb-3">
                            <label class="form-label">Nome</label>
                            <InputText class="form-control"
                                       @bind-Value="model.Name" />
                            <ValidationMessage For="@(() => model.Name)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText class="form-control"
                                       @bind-Value="model.Email" />
                            <ValidationMessage For="@(() => model.Email)" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Telefone</label>
                            <InputText class="form-control"
                                       @bind-Value="model.PhoneNumber" />
                            <ValidationMessage For="@(() => model.PhoneNumber)" />
                        </div>

                        <div class="d-flex justify-content-end gap-2">

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    @onclick="Cancel">
                                Cancelar
                            </button>

                            <button type="submit"
                                    class="btn btn-success">
                                Adicionar membro
                            </button>

                        </div>

                    </EditForm>

                </div>

            </div>

        </div>

    </div>

</div>

@code {

    private CreateMemberViewModel model = new();

    private async Task Save()
    {
        var request = new CreateMemberRequest(
            model.Name,
            model.Email,
            model.PhoneNumber);

        await MemberService.CreateMember(request);

        Nav.NavigateTo("/members");
    }

    private void Cancel()
    {
        Nav.NavigateTo("/members");
    }

}