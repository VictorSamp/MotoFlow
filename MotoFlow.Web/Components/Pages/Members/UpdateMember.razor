@page "/members/edit/{Id:guid}"

@using MotoFlow.Domain.Enums
@using MotoFlow.Web.Components.ViewModels.Members
@using MotoFlow.Application.Members.UpdateMember

@inject MemberApiService MemberService
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card shadow-sm">

                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">Editar Membro</h4>
                </div>

                <div class="card-body">

                    @if (model is null)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-3 mb-0">Carregando informações do membro...</p>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">
                            Atualize as informações do membro e clique em <strong>Salvar Alterações</strong>.
                        </p>

                        <EditForm Model="model"
                                  OnValidSubmit="Save"
                                  FormName="update-member-form">

                            <DataAnnotationsValidator />
                            <ValidationSummary class="text-danger mb-3" />

                            <div class="mb-3">
                                <label class="form-label">Nome</label>
                                <InputText class="form-control"
                                           @bind-Value="model.Name" />
                                <ValidationMessage For="@(() => model.Name)" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Telefone</label>
                                <InputText class="form-control"
                                           @bind-Value="model.PhoneNumber" />
                                <ValidationMessage For="@(() => model.PhoneNumber)" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Nível da Insígnia</label>

                                <InputSelect class="form-select"
                                             @bind-Value="model.CurrentPatchLevel">

                                    @foreach (var level in Enum.GetValues<PatchLevel>())
                                    {
                                        <option value="@level">@level</option>
                                    }

                                </InputSelect>

                            </div>

                            <div class="d-flex justify-content-end gap-2">

                                <button type="button"
                                        class="btn btn-outline-secondary"
                                        @onclick="Cancel">
                                    Cancelar
                                </button>

                                <button type="submit"
                                        class="btn btn-success">
                                    Salvar Alterações
                                </button>

                            </div>

                        </EditForm>
                    }

                </div>

            </div>

        </div>

    </div>

</div>

@code {

    [Parameter]
    public Guid Id { get; set; }

    private UpdateMemberViewModel? model;

    protected override async Task OnInitializedAsync()
    {
        var member = await MemberService.GetMemberById(Id);

        if (member is not null)
        {
            model = new UpdateMemberViewModel
            {
                Id = member.Id,
                Name = member.Name,
                PhoneNumber = member.PhoneNumber,
                CurrentPatchLevel = member.CurrentPatchLevel
            };
        }
    }

    private async Task Save()
    {
        if (model is null)
            return;

        var request = new UpdateMemberRequest(
            model.Name,
            model.PhoneNumber,
            model.CurrentPatchLevel);

        await MemberService.UpdateMember(Id, request);

        Nav.NavigateTo("/members");
    }

    private void Cancel()
    {
        Nav.NavigateTo("/members");
    }

}