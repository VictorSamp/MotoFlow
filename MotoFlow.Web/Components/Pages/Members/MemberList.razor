
@page "/members"
@inject MemberApiService MemberApiService

<h3>Membros</h3>

@if (members == null)
{
    <p>Carregando...</p>
}
else if (!members.Any())
{
    <p>Nenhum membro encontrado.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Email</th>
                <th>Telefone</th>
                <th>Data de ingresso</th>
                <th>Nivel da insignia</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var m in members)
            {
                <tr>
                    <td>@m.Name</td>
                    <td>@m.Email</td>
                    <td>@m.PhoneNumber</td>
                    <td>@m.JoinDate.ToShortDateString()</td>
                    <td>@m.CurrentPatchLevel</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<MemberDto>? members;

    protected override async Task OnInitializedAsync()
    {
        members = await MemberApiService.GetAllMembers();
    }
}